{
  "info": {
    "_postman_id": "mobicortex-master-api-v1",
    "name": "MobiCortex Master API",
    "description": "Coleção de endpoints da API da Controladora Master MobiCortex",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/login",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "login"
              ]
            },
            "description": "Autentica o usuário e retorna um token JWT"
          },
          "response": []
        },
        {
          "name": "Alterar Senha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"senha_atual\",\n  \"new_password\": \"nova_senha\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/change-password",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "change-password"
              ]
            },
            "description": "Altera a senha do usuário autenticado"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Configuração de Rede",
      "item": [
        {
          "name": "Obter Configuração",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://{{base_url}}/api/network",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "network"
              ]
            },
            "description": "Retorna as configurações de rede do dispositivo"
          },
          "response": []
        },
        {
          "name": "Atualizar Configuração",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ethernet\": {\n    \"dhcp\": false,\n    \"ip\": \"192.168.1.100\",\n    \"mask\": \"255.255.255.0\",\n    \"gateway\": \"192.168.1.1\"\n  },\n  \"wifi\": {\n    \"enabled\": true,\n    \"ssid\": \"MinhaRedeWiFi\",\n    \"password\": \"senha123\",\n    \"dhcp\": true,\n    \"ip\": \"\",\n    \"mask\": \"\",\n    \"gateway\": \"\"\n  },\n  \"server\": {\n    \"name\": \"Controladora de Acesso\",\n    \"port\": \"8080\"\n  }\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/network",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "network"
              ]
            },
            "description": "Atualiza as configurações de rede do dispositivo"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Veículos",
      "item": [
        {
          "name": "Listar Veículos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://{{base_url}}/api/veiculos?filtro=",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "veiculos"
              ],
              "query": [
                {
                  "key": "filtro",
                  "value": "",
                  "description": "Filtro opcional por placa ou proprietário"
                }
              ]
            },
            "description": "Retorna a lista de veículos cadastrados"
          },
          "response": []
        },
        {
          "name": "Obter Veículo",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://{{base_url}}/api/veiculos/{{veiculo_id}}",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "veiculos",
                "{{veiculo_id}}"
              ]
            },
            "description": "Retorna os detalhes de um veículo específico"
          },
          "response": []
        },
        {
          "name": "Criar Veículo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"placa\": \"ABC1234\",\n  \"tag_rfid\": \"A12B34C5\",\n  \"proprietario\": \"João Silva\",\n  \"tipo\": \"Morador\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/veiculos",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "veiculos"
              ]
            },
            "description": "Cadastra um novo veículo"
          },
          "response": []
        },
        {
          "name": "Atualizar Veículo",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"placa\": \"ABC1234\",\n  \"tag_rfid\": \"A12B34C5\",\n  \"proprietario\": \"João Silva Atualizado\",\n  \"tipo\": \"Morador\"\n}"
            },
            "url": {
              "raw": "http://{{base_url}}/api/veiculos/{{veiculo_id}}",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "veiculos",
                "{{veiculo_id}}"
              ]
            },
            "description": "Atualiza os dados de um veículo existente"
          },
          "response": []
        },
        {
          "name": "Excluir Veículo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://{{base_url}}/api/veiculos/{{veiculo_id}}",
              "protocol": "http",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "veiculos",
                "{{veiculo_id}}"
              ]
            },
            "description": "Remove um veículo do sistema"
          },
          "response": []
        }
      ]
    },
