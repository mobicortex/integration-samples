{
  "info": {
    "name": "MobiCortex Master API v1",
    "description": "Collection da API nativa MobiCortex Master.\n\nBase URL: {{baseUrl}}\nAuth: Bearer {{sessionKey}}\nTTL da sessao: 900 segundos\nEscopo: somente endpoints nativos da API Master.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://192.168.0.21:4449", "type": "string" },
    { "key": "password", "value": "admin", "type": "string" },
    { "key": "sessionKey", "value": "", "type": "string" },
    { "key": "apiToken", "value": "", "type": "string" },
    { "key": "centralRegistryId", "value": "0", "type": "string" },
    { "key": "entityId", "value": "0", "type": "string" },
    { "key": "vehicleId", "value": "0", "type": "string" },
    { "key": "driverIdsJson", "value": "[111,222]", "type": "string" },
    { "key": "mediaId", "value": "0", "type": "string" },
    { "key": "webhookId", "value": "1", "type": "string" },
    { "key": "devgid", "value": "123456", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{sessionKey}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Autenticacao",
      "description": "Login, logout e tokens de API.",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.ret === 0 && body.session_key) {",
                  "    pm.collectionVariables.set('sessionKey', body.session_key);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pass\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/login"
          }
        },
        {
          "name": "Alterar Senha",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pass_atual\": \"{{password}}\",\n  \"pass_nova\": \"nova_senha\",\n  \"pass_nova2\": \"nova_senha\"\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/login"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"session_key\": \"{{sessionKey}}\"\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/login"
          }
        },
        {
          "name": "Listar Tokens",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/token"
          }
        },
        {
          "name": "Criar Token com TTL",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.token) {",
                  "    pm.collectionVariables.set('apiToken', body.token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"ERP\",\n  \"ttl_days\": 365\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/token"
          }
        },
        {
          "name": "Criar Token com Expiracao",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"label\": \"Integracao temporaria\",\n  \"expires_at\": \"2026-12-31T23:59:59\"\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/token"
          }
        },
        {
          "name": "Remover Token",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{apiToken}}\"\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/token"
          }
        }
      ]
    },
    {
      "name": "Cadastro Central",
      "description": "Fluxos de listagem, busca, criacao e remocao de cadastro central.",
      "item": [
        {
          "name": "Listar Paginado",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry?offset=0&count=10"
          }
        },
        {
          "name": "Filtrar por Nome",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry?offset=0&count=10&name=Empresa"
          }
        },
        {
          "name": "Busca Consolidada",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry?search=ABC1D23"
          }
        },
        {
          "name": "Buscar por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry?id={{centralRegistryId}}"
          }
        },
        {
          "name": "Criar ou Atualizar",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.id) {",
                  "    pm.collectionVariables.set('centralRegistryId', String(body.id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 0,\n  \"name\": \"Empresa ABC Ltda\",\n  \"field1\": \"Bloco A\",\n  \"field2\": \"101\",\n  \"field3\": \"TI\",\n  \"field4\": \"Matriz\",\n  \"enabled\": true,\n  \"slots1\": 0,\n  \"slots2\": 0,\n  \"type\": 0\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry"
          }
        },
        {
          "name": "Remover",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry?id={{centralRegistryId}}"
          }
        },
        {
          "name": "Estatisticas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/central-registry/stats"
          }
        }
      ]
    },
    {
      "name": "Entidades",
      "description": "Pessoa, veiculo, busca avancada e atualizacao parcial.",
      "item": [
        {
          "name": "Listar Global",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?offset=0&count=10"
          }
        },
        {
          "name": "Listar por Cadastro",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?central_registry_id={{centralRegistryId}}"
          }
        },
        {
          "name": "Busca Avancada",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?offset=0&count=10&name=joao&doc=ABC1D23&type=2"
          }
        },
        {
          "name": "Buscar por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?id={{entityId}}"
          }
        },
        {
          "name": "Criar Pessoa",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.entity_id) {",
                  "    pm.collectionVariables.set('entityId', String(body.entity_id));",
                  "  }",
                  "  if (body && body.central_registry_id) {",
                  "    pm.collectionVariables.set('centralRegistryId', String(body.central_registry_id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 0,\n  \"type\": 1,\n  \"name\": \"Maria Oliveira\",\n  \"doc\": \"12345678900\",\n  \"central_registry_id\": {{centralRegistryId}},\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities"
          }
        },
        {
          "name": "Criar Veiculo com LPR",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.entity_id) {",
                  "    pm.collectionVariables.set('vehicleId', String(body.entity_id));",
                  "  }",
                  "  if (body && body.central_registry_id) {",
                  "    pm.collectionVariables.set('centralRegistryId', String(body.central_registry_id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 0,\n  \"type\": 2,\n  \"name\": \"Joao Silva Santos\",\n  \"doc\": \"ABC1D23\",\n  \"central_registry_id\": {{centralRegistryId}},\n  \"lpr_enabled\": true,\n  \"brand\": \"Toyota\",\n  \"model\": \"Corolla\",\n  \"color\": \"Branco\",\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities"
          }
        },
        {
          "name": "Criar com Auto-ID",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 0,\n  \"createid\": true,\n  \"type\": 1,\n  \"name\": \"Cadastro automatico\",\n  \"doc\": \"\",\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities"
          }
        },
        {
          "name": "Atualizar Entidade",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nome atualizado\",\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?id={{entityId}}"
          }
        },
        {
          "name": "Atualizar Veiculo",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Toyota\",\n  \"model\": \"Corolla XEI\",\n  \"color\": \"Prata\",\n  \"lpr_enabled\": true,\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?id={{vehicleId}}"
          }
        },
        {
          "name": "Remover Entidade",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/entities?id={{entityId}}"
          }
        }
      ]
    },
    {
      "name": "Condutores de Veiculo",
      "item": [
        {
          "name": "Listar Condutores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/vehicle-drivers?vehicle_id={{vehicleId}}"
          }
        },
        {
          "name": "Atualizar Condutores",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driver_ids\": {{driverIdsJson}}\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/vehicle-drivers?vehicle_id={{vehicleId}}"
          }
        }
      ]
    },
    {
      "name": "Midias",
      "description": "Exemplos de RFID e LPR manual. Para veiculo, prefira lpr_enabled na entidade.",
      "item": [
        {
          "name": "Listar por Entidade",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media?entity_id={{entityId}}"
          }
        },
        {
          "name": "Buscar por ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media?id={{mediaId}}"
          }
        },
        {
          "name": "Criar RFID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  if (body && body.media_id) {",
                  "    pm.collectionVariables.set('mediaId', String(body.media_id));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": {{entityId}},\n  \"central_registry_id\": {{centralRegistryId}},\n  \"type\": 21,\n  \"description\": \"123,45678\",\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media"
          }
        },
        {
          "name": "Criar LPR Manual",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_id\": {{vehicleId}},\n  \"central_registry_id\": {{centralRegistryId}},\n  \"type\": 17,\n  \"description\": \"ABC1D23\",\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media"
          }
        },
        {
          "name": "Atualizar Midia",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": false,\n  \"expiration\": 1767225600\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media?id={{mediaId}}"
          }
        },
        {
          "name": "Remover Midia",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/media?id={{mediaId}}"
          }
        }
      ]
    },
    {
      "name": "Sistema",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/dashboard"
          }
        },
        {
          "name": "Device Info",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/device-info"
          }
        },
        {
          "name": "Config GET",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/config"
          }
        },
        {
          "name": "Config POST",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"devgid\": {{devgid}},\n  \"master\": {\n    \"id\": 1,\n    \"frase\": \"MobiCortex\",\n    \"app\": \"RXPPRO\"\n  }\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/config"
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Listar Slots",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/webhook"
          }
        },
        {
          "name": "Buscar Slot",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/webhook?id={{webhookId}}"
          }
        },
        {
          "name": "Salvar Slot",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://example.com/webhook\",\n  \"registered\": 1,\n  \"unregistered\": 1,\n  \"sensors\": 0,\n  \"logs\": 0\n}"
            },
            "url": "{{baseUrl}}/mbcortex/master/api/v1/webhook?id={{webhookId}}"
          }
        },
        {
          "name": "Remover Slot",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/mbcortex/master/api/v1/webhook?id={{webhookId}}"
          }
        }
      ]
    }
  ]
}
